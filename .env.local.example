# SUPABASE CONFIGURATION (REQUIRED)
# Get these from https://supabase.com/dashboard/project/settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# API CONFIGURATION
NEXT_PUBLIC_API_URL=http://localhost:3000

# PAYMENT PROVIDER (Optional - for production payments)
# CASHFREE_KEY_ID=your_key_id
# CASHFREE_KEY_SECRET=your_key_secret

# DATABASE (Optional - if using external DB)
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# ERROR TRACKING (Optional - for production monitoring)
# NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ANALYTICS (Optional - for user analytics)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# NODE ENVIRONMENT
NODE_ENV=development
