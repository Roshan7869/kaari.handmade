# ===========================================
# Kaari Marketplace - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ===========================================

# -------------------------------------------
# Supabase Configuration (CLIENT-SAFE)
# These are safe to include in client-side code
# -------------------------------------------
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_SUPABASE_PROJECT_ID=your-project-id

# -------------------------------------------
# Payment Gateway (SERVER-SIDE ONLY)
# WARNING: DO NOT set these in .env for client!
# These should be Supabase Edge Function secrets only
# Client should call Edge Functions for payment operations
# -------------------------------------------
# VITE_CASHFREE_APP_ID=        # Use Edge Functions instead
# VITE_CASHFREE_SECRET_KEY=    # Use Edge Functions instead
# VITE_CASHFREE_WEBHOOK_SECRET=# Use Edge Functions instead
VITE_CASHFREE_TEST_MODE=true

# -------------------------------------------
# Feature Flags
# -------------------------------------------
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEVTOOLS=false

# -------------------------------------------
# Audit / Backend configs (for scripts only)
# These are used by audit scripts, not client code
# -------------------------------------------
# SUPABASE_SERVICE_KEY=your-service-role-key
# AUDIT_USER_EMAIL=test@example.com
# AUDIT_USER_PASS=testpassword

# -------------------------------------------
# Development Only
# -------------------------------------------
# KAARI_BASE_URL=http://localhost:8080